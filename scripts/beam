set -euo pipefail

resolve_script_path() {
  local source="${BASH_SOURCE[0]}"
  local dir=""
  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*)
        ;;
      *)
        source="$dir/$source"
        ;;
    esac
  done
  dir="$(cd -P "$(dirname "$source")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$source")"
}

script_path="$(resolve_script_path)"
script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"
if [ -n "${BEAM_HOME:-}" ]; then
  repo_root="$BEAM_HOME"
  if [ -x "$repo_root/libexec/beam-cli" ]; then
    beam_bin="$repo_root/libexec/beam-cli"
  else
    beam_bin="$repo_root/.lake/build/bin/beam-cli"
  fi
else
  repo_root="$(cd -P "$script_dir/.." && pwd)"
  beam_bin="$repo_root/.lake/build/bin/beam-cli"
  if [ ! -x "$beam_bin" ] && [ -x "$repo_root/libexec/beam-cli" ]; then
    beam_bin="$repo_root/libexec/beam-cli"
  fi
fi

if [ ! -x "$beam_bin" ]; then
  echo "missing beam CLI at $beam_bin" >&2
  echo "run: (cd \"$repo_root\" && lake build beam-cli)" >&2
  exit 1
fi

export BEAM_HOME="$repo_root"
exec "$beam_bin" "$@"
