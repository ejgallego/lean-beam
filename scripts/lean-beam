# Copyright (c) 2026 Lean FRO LLC. All rights reserved.
# Released under Apache 2.0 license as described in the file LICENSE.
# Author: Emilio J. Gallego Arias

set -euo pipefail

usage() {
  cat <<'EOF' >&2
usage:
  lean-beam --version
  lean-beam version
  lean-beam [--root PATH] [--port N] ensure [lean|rocq] [--hold]
  lean-beam [--root PATH] [--port N] run-at <path> <version> <line> <character> [--stdin | --text-file <path> | -- <text...> | <text...>]
  lean-beam [--root PATH] [--port N] run-at-handle <path> <version> <line> <character> [--stdin | --text-file <path> | -- <text...> | <text...>]
  lean-beam [--root PATH] [--port N] hover <path> <version> <line> <character>
  lean-beam [--root PATH] [--port N] goals-after <path> <version> <line> <character>
  lean-beam [--root PATH] [--port N] goals-prev <path> <version> <line> <character>
  lean-beam [--root PATH] [--port N] todo <path> <version> <startLine> <startCharacter> <endLine> <endCharacter> [--kind <kind> ...] [--suggest none|basic]
  lean-beam [--root PATH] [--port N] run-with <path> <handle-json|-|--handle-file <path>> [--stdin | --text-file <path> | -- <text...> | <text...>]
  lean-beam [--root PATH] [--port N] run-with-linear <path> <handle-json|-|--handle-file <path>> [--stdin | --text-file <path> | -- <text...> | <text...>]
  lean-beam [--root PATH] [--port N] release <path> <handle-json|-|--handle-file <path>>
  lean-beam [--root PATH] [--port N] update <path>
  lean-beam [--root PATH] [--port N] sync <path> [+full]
  lean-beam [--root PATH] [--port N] refresh <path> [+full]
  lean-beam [--root PATH] [--port N] save <path> [+full]
  lean-beam [--root PATH] [--port N] close <path>
  lean-beam [--root PATH] [--port N] close-save <path> [+full]
  lean-beam [--root PATH] [--port N] rocq-goals-after <path> <line> <character> [text...]
  lean-beam [--root PATH] [--port N] rocq-goals-prev <path> <line> <character> [text...]
  lean-beam supported-toolchains [lean]
  lean-beam [--root PATH] doctor [lean|rocq]
  lean-beam [--root PATH] open-files
  lean-beam [--root PATH] stats
  lean-beam [--root PATH] reset-stats
  lean-beam [--root PATH] shutdown
  lean-beam [--root PATH] cancel <request-id>

notes:
  - lean-beam keeps the Lean wrapper surface primary; optional Rocq goal probes are documented in docs/ROCQ.md
  - common Rocq entry points are `lean-beam ensure rocq`, `lean-beam doctor rocq`, `lean-beam rocq-goals-after`, and `lean-beam rocq-goals-prev`
  - run `lean-beam update <path>` first, then pass its returned `version` to Lean position/range probes
  - run `lean-beam sync <path>` when you also need the diagnostics/readiness barrier
  - for multiline text-carrying Lean probes, prefer `--stdin` or `--text-file <path>`; use `--` before text that starts with `--`
  - for handle-based commands, use `--handle-file <path>` when you do not want to inline handle json
  - use `ensure --hold` when a PID-isolated command runner needs one foreground process to keep a newly-started daemon alive
  - set `BEAM_DEBUG_TEXT=1` to print the exact escaped text and UTF-8 bytes sent for text-carrying Lean probes
  - use `lean-beam --version` for bug reports and installed runtime identity checks
EOF
}

resolve_script_path() {
  local source="${BASH_SOURCE[0]}"
  local dir=""
  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*)
        ;;
      *)
        source="$dir/$source"
        ;;
    esac
  done
  dir="$(cd -P "$(dirname "$source")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$source")"
}

script_path="$(resolve_script_path)"
script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"
beam_home_explicit=0
if [ -n "${BEAM_HOME:-}" ]; then
  beam_home="$BEAM_HOME"
  beam_home_explicit=1
else
  beam_home="$(cd -P "$script_dir/.." && pwd)"
fi
beam_bin=""
if [ "$beam_home_explicit" -eq 1 ]; then
  if [ -x "$beam_home/libexec/beam-cli" ]; then
    beam_bin="$beam_home/libexec/beam-cli"
  elif [ -x "$beam_home/.lake/build/bin/beam-cli" ]; then
    beam_bin="$beam_home/.lake/build/bin/beam-cli"
  fi
else
  if [ -x "$beam_home/.lake/build/bin/beam-cli" ]; then
    beam_bin="$beam_home/.lake/build/bin/beam-cli"
  elif [ -x "$beam_home/libexec/beam-cli" ]; then
    beam_bin="$beam_home/libexec/beam-cli"
  fi
fi

if [ -z "$beam_bin" ] || [ ! -x "$beam_bin" ]; then
  echo "missing beam-cli executable under $beam_home" >&2
  exit 1
fi

if [ -z "${BEAM_INSTALL_BUNDLE_DIR:-}" ]; then
  case "$beam_home" in
    */versions/*)
      install_root="$(cd -P "$beam_home/../.." && pwd)"
      default_install_bundle_dir="$install_root/state/install-bundles"
      if [ -d "$default_install_bundle_dir" ]; then
        export BEAM_INSTALL_BUNDLE_DIR="$default_install_bundle_dir"
      fi
      ;;
  esac
fi
export BEAM_HOME="$beam_home"

prefix=()
cmd=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --root|--port)
      [ "$#" -ge 2 ] || break
      prefix+=("$1" "$2")
      shift 2
      ;;
    *)
      cmd="$1"
      shift
      break
      ;;
  esac
done

rest=("$@")
mapped=()
display_cmd=""

if [ -z "$cmd" ]; then
  usage
  exit 0
fi

case "$cmd" in
  -h|--help|help)
    usage
    exit 0
    ;;
  run-at)
    mapped=("lean-run-at")
    display_cmd="$cmd"
    ;;
  run-at-handle)
    mapped=("lean-run-at-handle")
    display_cmd="$cmd"
    ;;
  hover)
    mapped=("lean-hover")
    display_cmd="$cmd"
    ;;
  goals-after)
    mapped=("lean-goals-after")
    display_cmd="$cmd"
    ;;
  goals-prev)
    mapped=("lean-goals-prev")
    display_cmd="$cmd"
    ;;
  todo)
    mapped=("lean-todo")
    display_cmd="$cmd"
    ;;
  run-with)
    mapped=("lean-run-with")
    display_cmd="$cmd"
    ;;
  run-with-linear)
    mapped=("lean-run-with-linear")
    display_cmd="$cmd"
    ;;
  release)
    mapped=("lean-release")
    display_cmd="$cmd"
    ;;
  update)
    mapped=("lean-update")
    display_cmd="$cmd"
    ;;
  sync)
    mapped=("lean-sync")
    display_cmd="$cmd"
    ;;
  refresh)
    mapped=("lean-refresh")
    display_cmd="$cmd"
    ;;
  save)
    mapped=("lean-save")
    display_cmd="$cmd"
    ;;
  close)
    mapped=("lean-close")
    display_cmd="$cmd"
    ;;
  close-save)
    mapped=("lean-close-save")
    display_cmd="$cmd"
    ;;
  request-at)
    mapped=("lean-request-at")
    display_cmd="$cmd"
    ;;
  ensure)
    if [ "${#rest[@]}" -eq 0 ]; then
      mapped=("ensure" "lean")
      rest=()
    else
      mapped=("ensure")
    fi
    ;;
  doctor)
    if [ "${#rest[@]}" -eq 0 ]; then
      mapped=("doctor" "lean")
      rest=()
    else
      mapped=("doctor")
    fi
    ;;
  supported-toolchains)
    if [ "${#rest[@]}" -eq 0 ]; then
      mapped=("supported-toolchains" "lean")
      rest=()
    else
      mapped=("supported-toolchains")
    fi
    ;;
  *)
    mapped=("$cmd")
    ;;
esac

if [ -n "$display_cmd" ]; then
  export BEAM_WRAPPER_COMMAND="$display_cmd"
else
  unset BEAM_WRAPPER_COMMAND
fi
case "$cmd" in
  version|--version)
    export BEAM_WRAPPER_PATH="$script_path"
    export BEAM_PUBLIC_COMMAND="lean-beam"
    ;;
  *)
    unset BEAM_WRAPPER_PATH
    unset BEAM_PUBLIC_COMMAND
    ;;
esac

if [ -n "${prefix[*]-}" ]; then
  if [ -n "${rest[*]-}" ]; then
    exec "$beam_bin" ${prefix[@]+"${prefix[@]}"} ${mapped[@]+"${mapped[@]}"} ${rest[@]+"${rest[@]}"}
  else
    exec "$beam_bin" ${prefix[@]+"${prefix[@]}"} ${mapped[@]+"${mapped[@]}"}
  fi
else
  if [ -n "${rest[*]-}" ]; then
    exec "$beam_bin" ${mapped[@]+"${mapped[@]}"} ${rest[@]+"${rest[@]}"}
  else
    exec "$beam_bin" ${mapped[@]+"${mapped[@]}"}
  fi
fi
