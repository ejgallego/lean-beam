set -euo pipefail

resolve_script_path() {
  local source="${BASH_SOURCE[0]}"
  local dir=""
  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*)
        ;;
      *)
        source="$dir/$source"
        ;;
    esac
  done
  dir="$(cd -P "$(dirname "$source")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$source")"
}

script_path="$(resolve_script_path)"
script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"
beam_home="${BEAM_HOME:-$(cd -P "$script_dir/.." && pwd)}"
if [ -x "$beam_home/bin/beam" ]; then
  beam_script="$beam_home/bin/beam"
else
  beam_script="$beam_home/scripts/beam"
fi

usage() {
  cat <<'EOF' >&2
usage:
  beam-lean-search [beam opts...] mint <path> <line> <character> <text...>
  beam-lean-search [beam opts...] branch <path> <text...>
  beam-lean-search [beam opts...] linear <path> <text...>
  beam-lean-search [beam opts...] playout <path> <step> [step...]
  beam-lean-search [beam opts...] release <path>

notes:
  - branch, linear, playout, and release read a prior wrapper response or handle JSON from stdin
  - beam opts such as --root and --port may appear before the subcommand
EOF
  exit 1
}

if [ ! -x "$beam_script" ]; then
  echo "missing beam wrapper at $beam_script" >&2
  exit 1
fi

beam_prefix=()
subcmd=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    mint|branch|linear|playout|release)
      subcmd="$1"
      shift
      break
      ;;
    *)
      beam_prefix+=("$1")
      shift
      ;;
  esac
done

[ -n "$subcmd" ] || usage

case "$subcmd" in
  mint)
    [ "$#" -ge 4 ] || usage
    path="$1"
    line="$2"
    character="$3"
    shift 3
    exec "$beam_script" "${beam_prefix[@]}" lean-run-at-handle "$path" "$line" "$character" "$@"
    ;;
  branch)
    [ "$#" -ge 2 ] || usage
    path="$1"
    shift
    exec "$beam_script" "${beam_prefix[@]}" lean-run-with "$path" - "$@"
    ;;
  linear)
    [ "$#" -ge 2 ] || usage
    path="$1"
    shift
    exec "$beam_script" "${beam_prefix[@]}" lean-run-with-linear "$path" - "$@"
    ;;
  release)
    [ "$#" -eq 1 ] || usage
    path="$1"
    exec "$beam_script" "${beam_prefix[@]}" lean-release "$path" -
    ;;
  playout)
    [ "$#" -ge 2 ] || usage
    path="$1"
    shift
    current="$(cat)"
    for step in "$@"; do
      current="$(printf '%s\n' "$current" | "$beam_script" "${beam_prefix[@]}" lean-run-with-linear "$path" - "$step")"
    done
    printf '%s\n' "$current"
    ;;
esac
